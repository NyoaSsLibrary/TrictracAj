local function fetchFirebase()
	local ok, result = pcall(function()
		local fn = _llRequestFn()
		if fn then
			local r = fn({
				Url = FIREBASE_URL,
				Method = "GET",
				Headers = { ["Accept"] = "application/json" },
				Timeout = 10,
			})
			if r and r.StatusCode == 200 and r.Body then
				return r.Body
			end
			return nil
		end
		return HttpService:GetAsync(FIREBASE_URL)
	end)
	if not ok or not result then return nil end
	local ok2, data = pcall(HttpService.JSONDecode, HttpService, result)
	if not ok2 or type(data) ~= "table" then return nil end
	return data
end

task.spawn(function()
	while true do
		task.wait(fetchInterval)
		local data = fetchFirebase()
		if not data then continue end

		local entries = {}

		if data.brainrot then
			table.insert(entries, data)
		else
			for _, v in pairs(data) do
				if type(v) == "table" then
					table.insert(entries, v)
				end
			end
		end

		local newBestJobId = nil

		for _, entry in ipairs(entries) do
			local name = tostring(entry.brainrot or entry.name or "Unknown")
			local genText = tostring(entry.generation or entry.gen or "$0/s")
			local mutation = tostring(entry.mutation or "None")
			local players = tostring(entry.players or "?/?")
			local jobId = tostring(entry.jobId or entry.job_id or "")
			local val = parseValue(genText)

			if val < minValue then continue end

			local key = name .. "_" .. jobId
			local isNew = not seenKeys[key]
			
			if isNew then
				seenKeys[key] = true
				createLogEntry(name, genText, mutation, players, jobId, val)

				if val > globalBestValue then
					globalBestValue = val
					newBestJobId = jobId
				end
			end
		end

		if isStarted and newBestJobId and newBestJobId ~= "" then
			doJoin(newBestJobId)
		end
	end
end)
