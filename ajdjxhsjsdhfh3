local function getBadgeColor(mutation)
	mutation = tostring(mutation or ""):lower()
	if mutation:find("secret") then return C.RED
	elseif mutation:find("mythic") then return C.PURPLE
	elseif mutation:find("legend") then return C.YELLOW
	elseif mutation:find("rare") then return C.BLUE
	end
	return C.GREEN2
end

local function doJoin(jobId)
	if not jobId then return end
	jobId = tostring(jobId):match("^%s*(.-)%s*$")
	if jobId == "" or jobId == "unknown" then return end
	local placeId = game.PlaceId
	pcall(function()
		if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
			Player.Character.HumanoidRootPart.Anchored = true
		end
	end)
	pcall(function()
		TeleportService:TeleportToPlaceInstance(placeId, jobId, Player)
	end)
end

