local function _llRequestFn()
	return (syn and syn.request) or (http and http.request) or http_request or request
end

local function _llUrlEncode(s)
	return (s:gsub("[^%w%-_%.~]", function(c)
		return string.format("%%%02X", string.byte(c))
	end))
end

local function _llFetchFandomImage(displayName)
	if _LL_imgCache[displayName] ~= nil then
		return _LL_imgCache[displayName] or nil
	end
	local ok, body = pcall(function()
		local apiUrl = "https://stealabrainrot.fandom.com/api.php"
			.. "?action=query&prop=pageimages&format=json&pithumbsize=256&titles="
			.. (displayName:gsub(" ", "_"))
		local fn = _llRequestFn()
		if fn then
			local r = fn({ Url = apiUrl, Method = "GET", Headers = { ["User-Agent"] = "Mozilla/5.0" }, Timeout = 8 })
			return (r and r.StatusCode == 200) and r.Body or nil
		end
		return HttpService:GetAsync(apiUrl)
	end)
	if ok and body then
		local thumb = body:match('"source":"(https://[^"]+)"')
			or body:match('"url":"(https://static%.wikia%.nocookie%.net[^"]+)"')
		if thumb then
			thumb = thumb:gsub("\\/", "/"):gsub("&amp;", "&")
			_LL_imgCache[displayName] = thumb
			return thumb
		end
	end
	local requestFn = _llRequestFn()
	if requestFn then
		local candidates = {}
		local clean = displayName:gsub("%[.-%]%s*", ""):gsub("^%s+", ""):gsub("%s+$", "")
		clean = clean:match("^(.-)%s*%(") or clean
		local seen = {}
		local function add(s)
			if s and s ~= "" and not seen[s] then seen[s] = true; table.insert(candidates, s) end
		end
		add((clean:gsub(" ", "_")))
		add(_llUrlEncode(clean))
		add((displayName:gsub(" ", "_")))
		add(_llUrlEncode(displayName))
		for _, slug in ipairs(candidates) do
			local pageBody
			local ok2, res = pcall(function()
				return requestFn({
					Url = "https://stealabrainrot.fandom.com/wiki/" .. slug,
					Method = "GET",
					Headers = { ["User-Agent"] = "Mozilla/5.0", ["Accept"] = "text/html", ["Cache-Control"] = "no-cache" },
					Timeout = 10,
				})
			end)
			if ok2 and res and res.StatusCode == 200 and res.Body and res.Body ~= "" then
				pageBody = res.Body
			end
			if pageBody then
				local og = pageBody:match('property="og:image"%s+content="([^"]+)"')
					or pageBody:match('content="([^"]+)"%s+property="og:image"')
				if og and og ~= "" then
					og = og:gsub("&amp;", "&"):gsub("&quot;", '"')
					if og:find("^https?://") then
						_LL_imgCache[displayName] = og
						return og
					end
				end
				for _, attr in ipairs({ "data%-src", "src" }) do
					local last
					for _, ext in ipairs({ "png", "jpg", "jpeg", "webp" }) do
						local pat = attr .. '="(https://[^"]+%.' .. ext .. '[^"]*)"'
						for u in pageBody:gmatch(pat) do
							if u:find("static%.wikia%.nocookie%.net") and not u:find("/scale%-to%-width%-down/%d%d?$") then
								last = u
							end
						end
					end
					if last then
						last = last:gsub("/revision/latest", "")
						_LL_imgCache[displayName] = last
						return last
					end
				end
			end
		end
	end
	_LL_imgCache[displayName] = false
	return nil
end

local function getImageForBrainrot(name)
	local img = _llFetchFandomImage(name)
	if img then return img end
	return "https://www.roblox.com/headshot-thumbnail/image?userId=" .. tostring(Player.UserId) .. "&width=420&height=420&format=png"
end

local function parseValue(text)
	if not text then return 0 end
	local s = tostring(text):gsub("%$", ""):gsub("/s", ""):gsub("%s", "")
	local num = tonumber(s:match("[%d%.]+")) or 0
	if s:find("[Bb]") then return num * 1e9
	elseif s:find("[Mm]") then return num * 1e6
	elseif s:find("[Kk]") then return num * 1e3
	else return num end
end

local function formatValue(num)
	if num >= 1e9 then return string.format("%.1fB", num / 1e9)
	elseif num >= 1e6 then return string.format("%.1fM", num / 1e6)
	elseif num >= 1e3 then return string.format("%.1fK", num / 1e3)
	else return tostring(num) end
end

