	local stroke = Instance.new("UIStroke")
	stroke.Parent = btn
	stroke.Color = default and C.BORDER or C.BORDER_DIM
	stroke.Thickness = 1
	stroke.Transparency = default and 0.05 or 0.35

	local underline = Instance.new("Frame")
	underline.Parent = btn
	underline.AnchorPoint = Vector2.new(0.5, 1)
	underline.Position = UDim2.new(0.5, 0, 1, 0)
	underline.Size = default and UDim2.new(0.75, 0, 0, 2) or UDim2.new(0, 0, 0, 2)
	underline.BackgroundColor3 = C.GREEN
	underline.BorderSizePixel = 0
	Instance.new("UICorner", underline).CornerRadius = UDim.new(0, 2)

	local data = { Button = btn, Stroke = stroke, Underline = underline, Page = pageName, Active = default }
	table.insert(tabs, data)

	btn.MouseEnter:Connect(function()
		if not data.Active then
			TweenService:Create(btn, tweenInfo, { BackgroundColor3 = Color3.fromRGB(16, 24, 16), TextColor3 = C.TEXT }):Play()
			TweenService:Create(stroke, tweenInfo, { Color = C.BORDER, Transparency = 0.12 }):Play()
		end
	end)
	btn.MouseLeave:Connect(function()
		if not data.Active then
			TweenService:Create(btn, tweenInfo, { BackgroundColor3 = Color3.fromRGB(18, 20, 18), TextColor3 = C.SUB }):Play()
			TweenService:Create(stroke, tweenInfo, { Color = C.BORDER_DIM, Transparency = 0.35 }):Play()
		end
	end)
	btn.MouseButton1Click:Connect(function()
		playClick()
		showPage(pageName)
		for _, t in ipairs(tabs) do
			t.Active = false
			TweenService:Create(t.Button, tweenInfo, { BackgroundColor3 = Color3.fromRGB(18, 20, 18), TextColor3 = C.SUB }):Play()
			TweenService:Create(t.Stroke, tweenInfo, { Color = C.BORDER_DIM, Transparency = 0.35 }):Play()
			TweenService:Create(t.Underline, tweenInfo, { Size = UDim2.new(0, 0, 0, 2) }):Play()
		end
		data.Active = true
		TweenService:Create(btn, tweenInfo, { BackgroundColor3 = Color3.fromRGB(18, 70, 34), TextColor3 = C.TEXT }):Play()
		TweenService:Create(stroke, tweenInfo, { Color = C.BORDER, Transparency = 0.05 }):Play()
		TweenService:Create(underline, tweenInfo, { Size = UDim2.new(0.75, 0, 0, 2) }):Play()
	end)
end

